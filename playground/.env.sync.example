# Local Mac sync agent (launchd: com.atriveo.cortex-sync)
# Copy to .env.sync and set DATABASE_URL to your Neon connection string.
SCREENPIPE_SYNC_ENABLED=1
SYNC_SECRET=change-me

# ScreenPipe paths on capture machine (external drive)
SCREENPIPE_DATA_DIR="/Volumes/Kasliwal v2/screenpipe-data"
SCREENPIPE_DB="/Volumes/Kasliwal v2/screenpipe-data/db.sqlite"
SCREENPIPE_PORT=3030
SCREENPIPE_API_URL=http://127.0.0.1:3030

# Neon (same as production Worker)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
