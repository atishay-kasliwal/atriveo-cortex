# Copy to .env.local and set paths for your machine.

# ScreenPipe SQLite database (readonly)
SCREENPIPE_DB=../data/screenpipe/db.sqlite

# Or set the data directory instead:
# SCREENPIPE_DATA_DIR=/path/to/screenpipe-data

# Writable extraction store
WORKING_MEMORY_DB=../data/working-memory.db

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
