{
  "name": "wm-extraction-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3456",
    "dev:archive": "tsx scripts/dev-archive.ts",
    "dev:watchdog": "tsx scripts/start-watchdog.ts",
    "build": "next build",
    "start": "next start -p 3456",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:install": "bash ../capture/install-capture-agents.sh",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate-cortex-to-neon.ts",
    "db:verify": "tsx scripts/verify-neon.ts",
    "sync:screenpipe": "tsx scripts/sync-screenpipe.ts",
    "capture:local": "tsx scripts/capture-to-local-knowledge.ts",
    "refresh:today-facts": "tsx scripts/refresh-today-facts.ts",
    "publish:today-facts": "tsx scripts/publish-today-facts-to-neon.ts",
    "pipeline:derived": "tsx scripts/pipeline-derived.ts",
    "build:sync": "esbuild scripts/sync-screenpipe.ts scripts/pipeline-derived.ts --bundle --platform=node --target=node20 --format=cjs --alias:@=. --external:better-sqlite3 --outdir=scripts --out-extension:.js=.cjs \"--banner:js=Object.defineProperty(globalThis,'__importMetaUrl',{get(){return require('url').pathToFileURL(__filename).href}});\" --define:import.meta.url=__importMetaUrl --log-level=warning",
    "build:derived": "npm run build:sync",
    "build:all": "npm run build:sync",
    "capture:watermark": "tsx scripts/capture-watermark.ts",
    "capture:recover": "tsx scripts/capture-stall-recovery.ts",
    "backfill:analytics": "tsx scripts/backfill-analytics.ts",
    "audit:history": "tsx scripts/audit-history.ts",
    "migrate:idle": "tsx scripts/migrate-idle-detection.ts",
    "migrate:activity-states": "tsx scripts/migrate-activity-states.ts",
    "migrate:sessions": "tsx scripts/migrate-session-intelligence.ts",
    "backfill:sessions": "tsx scripts/backfill-session-intelligence.ts",
    "migrate:attribution": "tsx scripts/migrate-project-attribution.ts",
    "migrate:open-loops": "tsx scripts/migrate-open-loop-intelligence.ts",
    "backfill:open-loops": "tsx scripts/backfill-open-loops.ts",
    "migrate:daily-reviews": "tsx scripts/migrate-daily-reviews.ts",
    "migrate:weekly-reviews": "tsx scripts/migrate-weekly-reviews.ts",
    "migrate:review-intelligence": "tsx scripts/migrate-review-intelligence.ts",
    "backfill:daily-reviews": "tsx scripts/backfill-daily-reviews.ts",
    "backfill:weekly-reviews": "tsx scripts/backfill-weekly-reviews.ts",
    "migrate:memory-search": "tsx scripts/migrate-memory-search.ts",
    "backfill:memory-search": "tsx scripts/backfill-memory-search.ts",
    "migrate:chat-analytics": "tsx scripts/migrate-chat-analytics.ts",
    "migrate:attention-engine": "tsx scripts/migrate-attention-engine.ts",
    "backfill:attention": "tsx scripts/backfill-attention.ts",
    "audit:attribution": "tsx scripts/audit-project-attribution.ts",
    "audit:chat": "tsx scripts/audit-conversational-cortex.ts",
    "audit:chat:v2": "tsx scripts/audit-conversational-cortex.ts",
    "healthcheck": "node ../scripts/healthcheck.mjs"
  },
  "dependencies": {
    "@cortex/builders": "*",
    "@cortex/knowledge": "*",
    "@cortex/models": "*",
    "better-sqlite3": "^11.9.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.3.3",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
