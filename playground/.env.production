# Production — Cortex API (Neon). Copy secrets to deployment host / CI.
DATABASE_URL=

NODE_ENV=production
CORTEX_DEPLOYMENT=cloud

APP_URL=https://cortex.atriveo.com
API_URL=https://cortex.atriveo.com
CORS_ORIGIN=https://cortex.atriveo.com

# Cloud API does not run ScreenPipe capture locally
SCREENPIPE_WATCHDOG=0
SCREENPIPE_SYNC_ENABLED=0

PORT=3456
RATE_LIMIT_PER_MINUTE=120
